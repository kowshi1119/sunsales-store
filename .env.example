# Database
DATABASE_URL=postgresql://user:password@host:5432/sunsales

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-min-32-chars

# Email (Resend or SMTP)
EMAIL_FROM=noreply@sunsales.lk
RESEND_API_KEY=re_xxxx
# Or SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=app-specific-password

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx

# Payment (PayHere)
PAYHERE_MERCHANT_ID=xxxx
PAYHERE_MERCHANT_SECRET=xxxx
PAYHERE_SANDBOX=true

# Redis (Upstash)
REDIS_URL=redis://xxxx

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=+94XXXXXXXXX

# Background Removal (optional)
REMOVE_BG_API_KEY=xxxx
